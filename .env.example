DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
PORT=3000

# PostgreSQL 连接串（Phase 1 必填）
# 标准端口: postgresql://postgres:funplanet123@127.0.0.1:5432/funplanet?schema=public
# Windows 若 5432/5433 被系统保留，改用 15432
DATABASE_URL="postgresql://postgres:funplanet123@127.0.0.1:15432/funplanet?schema=public"

# JWT 签名密钥（请改成随机长字符串，至少 32 位）
JWT_SECRET=change-this-to-a-long-random-secret-key
