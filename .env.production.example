# 复制为 .env 后填写，用于 docker compose up 部署线上 API
POSTGRES_PASSWORD=请改成强密码至少12位
JWT_SECRET=请改成至少32位随机字符串
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 通义万相 AI 绘画
DASHSCOPE_API_KEY=sk-your-dashscope-key
WANX_MODEL=wan2.6-t2i
WANX_SIZE=1280*1280

API_PORT=3000

# 管理后台域名，逗号分隔（例：https://admin.yourdomain.com）
CORS_ORIGINS=

# 生产环境默认 false，禁止管理员自助注册
ALLOW_ADMIN_REGISTER=false
